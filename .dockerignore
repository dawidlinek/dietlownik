# Dependencies and build output (rebuilt inside the image)
node_modules
.next
dist

# VCS and editor
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Local env (DATABASE_URL is passed at runtime, never baked in)
.env
.env.local
.env.*.local

# Web build doesn't need vitest config or the legacy Python scraper. Tests
# stay out of the image; everything else under scraper/ + db/ ships so the
# image can run scheduled scraper / migration jobs (see Dockerfile).
vitest.config.ts
scrape.py
scraper/__tests__

# Reverse-engineering artifacts (often contain auth tokens)
*.har

# Project / agent docs (not needed in production image)
README.md
AGENTS.md
CLAUDE.md
.impeccable.md
.claude
.agents
skills-lock.json

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts

# Logs and coverage
*.log
coverage

# Docker artifacts (don't recurse into ourselves)
Dockerfile
.dockerignore
docker-compose*.yml
